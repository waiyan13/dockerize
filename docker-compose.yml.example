networks:
  <org>_default:
    driver: bridge
    ipam:
      driver: default
      config: 
        - subnet: 172.24.0.0/24
          gateway: 172.24.0.1

services:
  postgres:
    build:
      context: ./postgres
      args:
        - POSTGRES_VERSION=${POSTGRES_VERSION}
        - TZ=${TZ}
    hostname: postgres
    environment:
      - PGPORT=${POSTGRES_PORT}
      - PGTZ=UTC
      - POSTGRES_PASSWORD=${POSTGRES_ROOT_PASSWORD}
    container_name: ${COMPOSE_PROJECT_NAME}_<org>_postgres_${POSTGRES_VERSION}
    image: ${COMPOSE_PROJECT_NAME}_<org>_postgres_${NGINX_VERSION}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready"]
      interval: 10s
      timeout: 5s
      retries: 5
    volumes:
      - ${DATA_PATH_HOST}/postgres:/var/lib/postgresql/data
      - ./postgres/docker-entrypoint-initdb.d:/docker-entrypoint-initdb.d
    networks:
      <org>_default:
        ipv4_address: 172.24.0.2

  mariadb:
    build:
      context: ./mariadb
      args:
        - MARIADB_VERSION=${MARIADB_VERSION}
        - TZ=${TZ}
    hostname: mariadb
    environment:
      - MARIADB_ROOT_PASSWORD=${MARIADB_ROOT_PASSWORD}
    container_name: ${COMPOSE_PROJECT_NAME}_<org>_mariadb_${MARIADB_VERSION}
    image: ${COMPOSE_PROJECT_NAME}_<org>_mariadb_${NGINX_VERSION}
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      start_period: 10s
      interval: 10s
      timeout: 5s
      retries: 3
    ports:
      - "${MARIADB_PORT}:3306"
    volumes:
      - ${DATA_PATH_HOST}/mariadb:/var/lib/mysql
      - ./mariadb/docker-entrypoint-initdb.d:/docker-entrypoint-initdb.d
    networks:
      <org>_default:
        ipv4_address: 172.24.0.3

  nginx:
    build:
      context: ./nginx
      args:
        - NGINX_VERSION=${NGINX_VERSION}
        - TZ=${TZ}
    container_name: ${COMPOSE_PROJECT_NAME}_<org>_nginx_${NGINX_VERSION}
    image: ${COMPOSE_PROJECT_NAME}_<org>_nginx_${NGINX_VERSION}
    ports:
      - "${NGINX_HTTP}:80"
      - "${NGINX_HTTPS}:443"
    volumes:
      - ${DATA_PATH_HOST}/nginx:/var/log/nginx
      - ${NGINX_SITES_PATH}:/etc/nginx/sites-available
      - ${NGINX_SSL_PATH}:/etc/nginx/ssl
    networks:
      <org>_default:
        ipv4_address: 172.24.0.4

  node:
    build:
      context: ./node
      args:
        - INSTALL_VERSION=${NODE_VERSION}
        - TZ=${TZ}
    container_name: ${COMPOSE_PROJECT_NAME}_<org>_node_${NODE_VERSION}
    image: ${COMPOSE_PROJECT_NAME}_<org>_node_${NODE_VERSION}
    volumes:
      - ${UI_CODE_PATH_HOST}:${APP_CODE_PATH_CONTAINER}
      - /home/waiyan13/.local/share/pnpm:/home/node/.local/share/pnpm
    ports:
      - "${NODE_PORT}:${NODE_PORT}"
    networks:
      <org>_default:
        ipv4_address: 172.24.0.5
    tty: true

  python:
    build:
      context: ./python
      args:
        - PYTHON_VERSION=${PYTHON_VERSION}
        - UV_VERSION=${PYTHON_UV_VERSION}
        - TZ=${TZ}
    container_name: ${COMPOSE_PROJECT_NAME}_<org>_python_${PYTHON_VERSION}
    image: ${COMPOSE_PROJECT_NAME}_<org>_python_${PYTHON_VERSION}
    volumes:
      - ${API_CODE_PATH_HOST}:${APP_CODE_PATH_CONTAINER}
    ports:
      - "${PYTHON_PORT}:${PYTHON_PORT}"
    networks:
      <org>_default:
        ipv4_address: 172.24.0.6
    tty: true

  #rust:
  #  build:
  #    context: ./rust
  #    args:
  #      - RUST_VERSION=${RUST_VERSION}
  #      - TZ=${TZ}
  #      - RUST_PORT=${RUST_PORT}
  #  container_name: ${COMPOSE_PROJECT_NAME}_<org>_rust_${RUST_VERSION}
  #  image: ${COMPOSE_PROJECT_NAME}_<org>_rust_${RUST_VERSION}
  #  volumes:
  #    - ${API_CODE_PATH_HOST}:${APP_CODE_PATH_CONTAINER}
  #  ports:
  #    - "${RUST_PORT}:${RUST_PORT}"
  #  networks:
  #    nexasea_default:
  #      ipv4_address: 10.202.1.7
  #  tty: true

  go:
    build:
      context: ./go
      additional_contexts:
        - ca_certs=./nginx/ssl
      args:
        - GO_VERSION=${GO_VERSION}
        - TZ=${TZ}
        - GO_PORT=${GO_PORT}
    container_name: ${COMPOSE_PROJECT_NAME}_<org>_go_${GO_VERSION}
    image: ${COMPOSE_PROJECT_NAME}_<org>_go_${GO_VERSION}
    volumes:
      - ${API_CODE_PATH_HOST}:${APP_CODE_PATH_CONTAINER}
    ports:
      - "${GO_PORT}:${GO_PORT}"
    networks:
      <org>_default:
        ipv4_address: 172.24.0.8
    extra_hosts:
      - "keycloak.test:172.24.0.4"
    tty: true

  keycloak:
    build:
      context: ./keycloak
      args:
        - KEYCLOAK_VERSION=${KEYCLOAK_VERSION}
        - KEYCLOAK_DATABASE=${KEYCLOAK_DATABASE}
    depends_on:
      mariadb:
        condition: service_healthy
        restart: true
    container_name: ${COMPOSE_PROJECT_NAME}_<org>_keycloak_${KEYCLOAK_VERSION}
    environment:
      - KC_DB=${KEYCLOAK_DATABASE}
      - KC_DB_URL_HOST=${KEYCLOAK_DATABASE}
      - KC_DB_USERNAME=${KEYCLOAK_DATABASE_USERNAME}
      - KC_DB_PASSWORD=${KEYCLOAK_DATABASE_PASSWORD}
      - KC_DB_URL=${KEYCLOAK_DATABASE_URL}
      - KC_HOSTNAME=${KEYCLOAK_BASE_URL}
      - KC_HTTP_ENABLED=true
      - KC_HTTP_PORT=${KEYCLOAK_PORT}
      - KC_PROXY_HEADERS=xforwarded
      - KC_BOOTSTRAP_ADMIN_USERNAME=${KEYCLOAK_BOOTSTRAP_ADMIN}
      - KC_BOOTSTRAP_ADMIN_PASSWORD=${KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD}
    image: ${COMPOSE_PROJECT_NAME}_<org>_keycloak_${KEYCLOAK_VERSION}
    ports:
      - ${KEYCLOAK_PORT}:${KEYCLOAK_PORT}
    networks:
      <org>_default:
        ipv4_address: 172.24.0.9
    tty: true

  #dex:
  #  build:
  #    context: ./dex
  #    args:
  #      - DEX_VERSION=${DEX_VERSION}
  #      - DEX_PORT=${DEX_PORT}
  #  image: ${COMPOSE_PROJECT_NAME}_<org>_dex_${DEX_VERSION}
  #  container_name: ${COMPOSE_PROJECT_NAME}_<org>_dex_${KEYCLOAK_VERSION}
  #  environment:
  #    - DEX_ISSUER=${DEX_ISSUER}
  #    - DEX_POSTGRES_HOST=${DEX_POSTGRES_HOST}
  #    - DEX_POSTGRES_DB=${DEX_POSTGRES_DB}
  #    - DEX_POSTGRES_USER=${DEX_POSTGRES_USER}
  #    - DEX_POSTGRES_PASSWORD=${DEX_POSTGRES_PASSWORD}
  #    - DEX_EXPIRY_DEVICE_REQUESTS=${DEX_EXPIRY_DEVICE_REQUESTS}
  #    - DEX_EXPIRY_SIGNING_KEYS=${DEX_EXPIRY_SIGNING_KEYS}
  #    - DEX_EXPIRY_ID_TOKENS=${DEX_EXPIRY_ID_TOKENS}
  #    - DEX_EXPIRY_AUTH_REQUESTS=${DEX_EXPIRY_AUTH_REQUESTS}
  #    - DEX_EXPIRY_REFRESH_TOKEN=${DEX_EXPIRY_REFRESH_TOKEN}
  #    - DEX_EXPIRY_REFRESH_TOKEN_INVALID=${DEX_EXPIRY_REFRESH_TOKEN_INVALID}
  #    - DEX_OAUTH2_RESPONSE_TYPES=${DEX_OAUTH2_RESPONSE_TYPES}
  #    - DEX_OAUTH2_SKIP_APPROVAL_SCREEN=${DEX_OAUTH2_SKIP_APPROVAL_SCREEN}
  #    - DEX_OAUTH2_ALWAYS_SHOW_LOGIN_SCREEN=${DEX_OAUTH2_ALWAYS_SHOW_LOGIN_SCREEN}
  #    - DEX_GRPC_ADDR=${DEX_GRPC_ADDR}
  #  volumes:
  #    - ./dex/config.docker.yaml:/etc/dex/config.docker.yaml
  #  ports:
  #    - "${DEX_PORT}:${DEX_PORT}"
  #  networks:
  #    nexasea_default:
  #      ipv4_address: 10.202.1.10
  #  tty: true

  mailpit:
    image: axllent/mailpit
    container_name: ${COMPOSE_PROJECT_NAME}_<org>_mailpit
    restart: unless-stopped
    volumes:
      - ${DATA_PATH_HOST}/mailpit:/data
    ports:
      - "${MAILPIT_SMTP_PORT}:${MAILPIT_SMTP_PORT}"
      - "${MAILPIT_HTTP_PORT}:${MAILPIT_HTTP_PORT}"
    networks:
      <org>_default:
        ipv4_address: 172.24.0.11
    environment:
      MP_MAX_MESSAGES: 5000
      MP_DATABASE: /data/mailpit.db
      MP_SMTP_AUTH_ACCEPT_ANY: 1
      MP_SMTP_AUTH_ALLOW_INSECURE: 1

  swagger:
    image: docker.swagger.io/swaggerapi/swagger-editor
    container_name: ${COMPOSE_PROJECT_NAME}_<org>_swagger_editor
    environment:
      PORT: ${SWAGGER_HTTP_PORT} 
    ports:
      - "${SWAGGER_HTTP_PORT}:${SWAGGER_HTTP_PORT}"
    networks:
      <org>_default:
        ipv4_address: 172.24.0.12

  mongodb:
    image: mongo:${MONGO_VERSION}-noble
    container_name: ${COMPOSE_PROJECT_NAME}_<org>_mongo_${MONGO_VERSION}
    healthcheck:
      test: ["CMD", "mongosh", "--eval", "db.adminCommand('ping')"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    environment:
      - MONGO_INITDB_ROOT_USERNAME=${MONGO_ROOT_USERNAME}
      - MONGO_INITDB_ROOT_PASSWORD=${MONGO_ROOT_PASSWORD}
    ports:
      - "${MONGO_PORT}:${MONGO_PORT}"
    volumes:
      - ./mongo/docker-entrypoint-initdb.d:/docker-entrypoint-initdb.d
      - ${DATA_PATH_HOST}/mongo:/data/db
    networks:
      vaudit_default:
        ipv4_address: 172.24.0.13

  redis:
    image: redis:${REDIS_VERSION}-alpine
    container_name: ${COMPOSE_PROJECT_NAME}_<org>_redis_${REDIS_VERSION}
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    ports:
      - "${REDIS_PORT}:${REDIS_PORT}"
    volumes:
      - ${DATA_PATH_HOST}/redis:/data
    networks:
      vaudit_default:
        ipv4_address: 172.24.0.14
